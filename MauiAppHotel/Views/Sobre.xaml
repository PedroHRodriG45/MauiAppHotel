<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="NewPage1"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#EAF4F4">

    <VerticalStackLayout Padding="30"
                         Spacing="15"
                         VerticalOptions="Center">
        <Label Text="Sobre o Aplicativo"
               FontFamily="PlayfairItalic"
               FontSize="40"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="#1D3557"/>

        <Label Text="Desenvolvedor: Pedro Henrique Rodrigues Gonçalves"
               TextColor="#1D3557"/>

        <Label Text="Ano: 2026"
               TextColor="#1D3557"/>

        <Label Text="Versão: 1.0"
               TextColor="#1D3557"/>

        <Label Text="Aplicativo desenvolvido para gerenciamento e contratação de hospedagens."
               TextColor="#1D3557"/>

        <Button Text="Voltar"
        BackgroundColor="#1D3557"
        TextColor="White"
        CornerRadius="10"
        HorizontalOptions="Center"
        Clicked="Voltar_Clicked"/>

    </VerticalStackLayout>
    
</ContentPage>